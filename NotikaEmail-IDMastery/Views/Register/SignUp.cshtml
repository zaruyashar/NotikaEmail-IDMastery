@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>Identity Kayıt Formu</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <link rel="stylesheet" type="text/css" href="/colorlib-regform-35/css/nunito-font.css">
    <link rel="stylesheet" href="/colorlib-regform-35/css/style.css" />
</head>

<body class="form-v9">
    <div class="page-content">
        <div class="form-v9-content" style="background-image: url('/colorlib-regform-35/images/form-v9.jpg')">

            <form class="form-detail" action="#" method="post">
                <h2>Yeni Kullanıcı Kaydı</h2>

                <div class="form-row-total">
                     <!--- frontend html pattern validation is a critical
                            security risk; additional backend validation is a must --->
                    <div class="form-row">
                        <input type="text" class="input-text" placeholder="Adınız">
                    </div>
                    <div class="form-row">
                        <input type="text" class="input-text" placeholder="Soyadınız">
                    </div>
                </div>

                <div class="form-row-total">
                    <div class="form-row">
                        <input type="email" class="input-text"
                               placeholder="E-posta adresiniz">
                    </div>
                    <div class="form-row">
                        <input type="text" class="input-text"
                               placeholder="Kullanıcı adınız">
                    </div>
                </div>

                <div class="form-row-total">
                    <div class="form-row">
                        <input type="password" class="input-text"
                               placeholder="Şifreniz">
                    </div>
                    <div class="form-row">
                        <input type="password" class="input-text"
                               placeholder="Şifre (Tekrar)">
                    </div>
                </div>

                <div class="form-row-last">
                    <input type="submit" class="register" value="Kaydol">
                </div>
            </form>
        </div>
    </div>
</body>
</html>